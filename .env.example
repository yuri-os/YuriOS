# Build #5 config (SPEC §11 + §25). Copy to .env. Every knob has a default in
# world/config.py (which extends Build #2's desktop/config.py, which extends the
# Build #1 brain's app/config.py); this file shows the ones you'll actually touch.

# --- the brain (Build #1, reused) — see Build #2's .env.example for the full story
# The model id's PREFIX picks the provider: lm_studio/… | ollama/… | openrouter/…
CHAT_MODEL=lm_studio/google/gemma-4-12b-qat
UTILITY_MODEL=lm_studio/google/gemma-4-12b-qat
LMSTUDIO_BASE_URL=http://localhost:1234/v1
# Local Ollama server — routes ollama/… model ids and lets the settings panel
# list the models you've pulled.
OLLAMA_BASE_URL=http://localhost:11434
OPENROUTER_API_KEY=

# Real-time voice: reply <think> OFF, utility <think> ON (B2 §2.5–§2.6).
CHAT_THINKING=false
UTILITY_THINKING=true
UTILITY_MAX_TOKENS=2048

# Embeddings stay local (B2 §2.4). sentence_tf runs the model IN-PROCESS via the
# bundled sentence-transformers package (weights pulled from HuggingFace once) —
# no LM Studio or Ollama required, the fully-standalone option. To reuse a local
# server instead, set EMBED_BACKEND=lm_studio (or ollama) with its embedding
# model — e.g. text-embedding-nomic-embed-text-v1.5 @ EMBED_DIM=768. EMBED_MODEL
# and EMBED_DIM must match the backend (a mismatch fails at reindex).
EMBED_BACKEND=sentence_tf
EMBED_MODEL=BAAI/bge-small-en-v1.5
EMBED_DIM=384

# Her own Vault (standalone). Seed once: `python scripts/seed_vault.py`. Point at a
# Build #1/#2 Vault to *continue* that companion (SPEC §2.4) — she is the folder.
VAULT_DIR=./vault
SOUL_SRC=./soul-src

HOST=127.0.0.1
PORT=8768

# --- voice (vendored Build #2 stack; see its .env.example for every knob) -----
STT_BACKEND=faster_whisper        # faster_whisper | fake
STT_MODEL=base.en
TTS_BACKEND=kokoro                # kokoro (default, CPU) | qwen3_tts | gpt_sovits | fake
VAD_BACKEND=silero                # silero | fake
MASK_LATENCY=true
MAX_REPLY_TOKENS=1600

# --- the hands: tools over MCP (SPEC §7) --------------------------------------
# mcp = real in-repo MCP server over stdio (the default; needs the `mcp` package,
# installed with the build). fake = deterministic offline results. off = no hands.
TOOLS_BACKEND=mcp                 # mcp | fake | off
TOOL_MAX_CALLS_PER_TURN=2         # per-turn cap (§7.3)
TOOL_TIMEOUT_S=10                 # per-call timeout
TOOL_LOG_DIR=./tool-logs          # one JSONL audit line per call, allowed or denied
# Per-tool rate limits, calls per minute (token bucket, §7.3):
TOOL_RATE_TIMER=6
TOOL_RATE_MUSIC=6
TOOL_RATE_WEATHER=4
TIMER_MAX_MINUTES=180             # set_timer upper bound (§7.1)
WEATHER_BACKEND=open_meteo        # open_meteo (real lookup, keyless) | fake
WEATHER_CITY=Tokyo                # default city when she isn't told one

# Her camera (§7.6): take_selfie renders through the vendored forge (./forge).
# openrouter = hosted (needs OPENROUTER_API_KEY above; GPU stays free for her
# voice). mock = placeholder cards, keyless. off = no camera. No key with
# openrouter set? She degrades to mock with one loud WARNING. The default model
# is the cheap one; sourceful/riverflow-v2.5-pro is the brand-art register.
SELFIE_BACKEND=openrouter         # openrouter | mock | off
SELFIE_MODEL=bytedance-seed/seedream-4.5
SELFIE_DIR=./selfies              # saved shots + their provenance ledger (/selfies/)
TOOL_RATE_SELFIE=2                # calls/minute — images are expensive

# --- the mind: the always-on tick loop (SPEC §15–§18) -----------------------------
MIND_ENABLED=true                 # off = Build #4 behaviour, minus the ambient life
MIND_SEED=0                       # 0 = unseeded; tests pin a seed for determinism
MIND_ACT_THRESHOLD=0.4            # gate 1: salience-to-act (most ticks REST below it)
MIND_INTERRUPT_THRESHOLD=0.75     # gate 2: salience-to-interrupt — YOUR dial (§18.2)
MIND_MAX_INTERRUPTS_PER_DAY=3     # the hard daily cap on her reaching out first
MIND_DAILY_TOKENS=200000          # the budget governor's cap (§17.3)
MIND_DREAM_TICK_TOKENS=4000       # per-DREAM-tick consolidation budget (§21)
MIND_ENGAGED_CADENCE_S=2          # tick cadence per activity state (§17.1)…
MIND_IDLE_CADENCE_S=60
MIND_DORMANT_CADENCE_S=900
MIND_DREAM_CADENCE_S=5
MIND_ENGAGED_TIMEOUT_S=180        # …and the drift down the cost ladder
MIND_IDLE_TIMEOUT_S=3600
MIND_DREAM_START_HOUR=2           # local window DORMANT may enter DREAM
MIND_DREAM_END_HOUR=6

# body reflexes + the murmur (§15.5 — the old idle machine's windows, kept)
IDLE_SETTLE_S=20                  # quiet time after a turn before ambient life resumes
IDLE_ACT_MIN_S=8                  # reflex window (gaze drift, expression pulse…)
IDLE_ACT_MAX_S=25
IDLE_TALK_MIN_S=120               # the self-talk impulse: one short spoken
IDLE_TALK_MAX_S=300               #   in-character line after this much quiet

# --- channels: the mediums beyond this origin (SPEC §10.5) ----------------------
# A channel is on when its credentials are set. Telegram: make a bot with
# @BotFather, paste its token; leave TELEGRAM_CHAT_ID empty for the first run,
# message the bot once, and it replies with the id to paste here (pairing mode —
# she binds to exactly one chat, and strangers are ignored).
#TELEGRAM_BOT_TOKEN=
#TELEGRAM_CHAT_ID=
# The terminal channel needs no config: `python -m yurios.chat` against a
# running server. WhatsApp + a game-engine NPC API are planned on the same seam.

# --- the room (SPEC §6) --------------------------------------------------------
RAIN_INTENSITY=0.6                # 0..1; she can't change the weather, but you can

# --- the desktop window (`python -m yurios.world --window`, SPEC §6.5–§6.6) -----
# The room set aside: a frameless, transparent, always-on-top native window with
# just her in it (needs the [desktop] extra). The frame knobs are the vendored
# B2 §9 set; DESKTOP_BODY picks which body floats in it.
DESKTOP_BODY=vrm                  # vrm (the 3D stage) | live2d (the vendored B2 client)
#AVATAR_MODEL=hiyori              # which Live2D rig, if live2d (fetch: scripts/fetch_live2d.py)
WINDOW_WIDTH=360
WINDOW_HEIGHT=640
WINDOW_ON_TOP=true
#WINDOW_GUI=gtk                   # engine override: "" auto (Chromium if installed — crisper) | qt | gtk

# With the local defaults above, nothing needs a cloud key — pull the network
# cable and she still runs (get_weather degrades gracefully; everything else is
# on-device).
